enum BlogPostStatus {
  DRAFT
  PUBLISHED
}

model BlogTopic {
  id           String    @id @default(uuid())
  name         String    @db.VarChar(255)
  slug         String    @unique @db.VarChar(255)
  description  String?   @db.Text
  parentId     String?   @map("parent_id")
  imageMediaId String?   @map("image_media_id")
  isActive     Boolean   @default(true) @map("is_active")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  deletedAt    DateTime? @map("deleted_at")
  sortOrder    Int       @default(0) @map("sort_order")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  parent     BlogTopic?  @relation("BlogTopicTree", fields: [parentId], references: [id], onDelete: SetNull)
  children   BlogTopic[] @relation("BlogTopicTree")
  imageMedia Media?      @relation("BlogTopicImage", fields: [imageMediaId], references: [id], onDelete: Restrict)
  posts      BlogPost[]

  @@index([slug])
  @@index([parentId])
  @@index([imageMediaId])
  @@index([isDeleted])
  @@map("blog_topics")
}

model BlogPost {
  id              String         @id @default(uuid())
  title           String         @db.VarChar(500)
  slug            String         @unique @db.VarChar(500)
  content         String         @db.Text
  excerpt         String?        @db.VarChar(500)
  topicId         String?        @map("topic_id")
  authorId        String         @map("author_id")
  featuredImageId String?        @map("featured_image_id")
  status          BlogPostStatus @default(DRAFT)
  tags            String[]       @default([])
  viewCount       Int            @default(0) @map("view_count")
  metaTitle       String?        @map("meta_title") @db.VarChar(255)
  metaDescription String?        @map("meta_description") @db.VarChar(500)
  isDeleted       Boolean        @default(false) @map("is_deleted")
  deletedAt       DateTime?      @map("deleted_at")
  publishedAt     DateTime?      @map("published_at")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  topic         BlogTopic? @relation(fields: [topicId], references: [id], onDelete: SetNull)
  author        User       @relation("BlogPostAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  featuredImage Media?     @relation("BlogPostFeaturedImage", fields: [featuredImageId], references: [id], onDelete: Restrict)

  @@index([slug])
  @@index([topicId])
  @@index([authorId])
  @@index([status])
  @@index([isDeleted])
  @@index([publishedAt])
  @@map("blog_posts")
}
